{
  "clickhouse_container": {
    "cpus": 6.0,
    "ram_limit": "8g"
  },
  "scenario_config": {
    "duration_per_instance_sec": 30.0,
    "insert_batch_size_list": [
      3000,
      5000,
      8000
    ],
    "writer_thread_list": [
      3,
      4,
      5
    ],
    "reader_threads": 10,
    "max_retries": 3,
    "insert_request_timeout_seconds": 10.0,
    "read_request_timeout_seconds": 20.0
  },
  "warmup": {
    "enabled": true,
    "duration_seconds": 15
  }
}