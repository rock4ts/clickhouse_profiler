<?xml version="1.0"?>
<company>
    <profiles>
        <default>
            <distributed_ddl_entry_format_version>2</distributed_ddl_entry_format_version>
            <max_memory_usage>4294967296</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>random</load_balancing>
            <log_queries>1</log_queries>
        </default>
        <etl_profile>
            <max_memory_usage>2147483648</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <log_queries>1</log_queries>
        </etl_profile>
        <readonly_profile>
            <readonly>1</readonly>
            <max_memory_usage>2147483648</max_memory_usage>
            <max_threads>4</max_threads>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <log_queries>1</log_queries>
        </readonly_profile>
    </profiles>

    <users>
        <default>
            <password from_env="CLICKHOUSE_DEFAULT_PASSWORD"/>
            <profile>default</profile>
            <networks>
                <ip>::/0</ip>
            </networks>
            <quota>default_quota</quota>
        </default>
        <admin>
            <password from_env="CLICKHOUSE_ADMIN_PASSWORD"/>
            <profile>default</profile>
            <access_management>1</access_management>
            <networks>
                <ip>::/0</ip>
            </networks>
            <quota>admin_quota</quota>
        </admin>
        <etl_writer>
            <password from_env="CLICKHOUSE_ETL_PASSWORD"/>
            <profile>etl_profile</profile>
            <networks>
                <ip>::/0</ip>
            </networks>
            <quota>etl_quota</quota>
        </etl_writer>
        <analytics_ro>
            <password from_env="CLICKHOUSE_ANALYTICS_PASSWORD"/>
            <profile>readonly_profile</profile>
            <networks>
                <ip>::/0</ip>
            </networks>
            <quota>analytics_quota</quota>
        </analytics_ro>
    </users>

    <quotas>
        <default_quota>
            <interval>
                <duration>3600</duration>
                <queries>1000</queries>
                <errors>100</errors>
                <result_rows>10000000</result_rows>
                <read_rows>100000000</read_rows>
                <execution_time>1800</execution_time>
            </interval>
        </default_quota>
        <admin_quota>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </admin_quota>
        <etl_quota>
            <interval>
                <duration>3600</duration>
                <queries>200000</queries>
                <errors>2000</errors>
                <result_rows>0</result_rows>
                <read_rows>2000000000</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </etl_quota>
        <analytics_quota>
            <interval>
                <duration>3600</duration>
                <queries>20000</queries>
                <errors>500</errors>
                <result_rows>200000000</result_rows>
                <read_rows>5000000000</read_rows>
                <execution_time>18000</execution_time>
            </interval>
        </analytics_quota>
    </quotas>
</company>